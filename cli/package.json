{
  "name": "task-kit-cli",
  "version": "0.5.3",
  "private": false,
  "description": "Task-Kit CLI",
  "license": "MIT",
  "bin": {
    "task-kit": "src/index.js"
  },
  "files": [
    "src",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "sync-skills": "node scripts/generate-skills.js",
    "sync-templates": "npm run sync-skills && node scripts/sync-templates.js",
    "prepack": "npm run sync-templates",
    "pack:release": "npm pack",
    "start": "node src/index.js",
    "init": "node src/index.js init",
    "check:js": "node --check src/index.js && node --check src/services/init.js && node --check src/services/lint.js",
    "lint:md": "markdownlint-cli2 \"../**/*.md\" \"#../node_modules\" \"#../.git\" \"#../cli/node_modules\" --config ../.markdownlint.jsonc",
    "check": "npm run check:js && npm run lint:md",
    "test": "node --test"
  },
  "dependencies": {
    "markdownlint-cli2": "0.23.1"
  }
}
