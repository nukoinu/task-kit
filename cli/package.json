{
  "name": "task-kit-cli",
  "version": "0.1.0",
  "private": false,
  "description": "Task-Kit CLI",
  "license": "MIT",
  "bin": {
    "task-kit": "src/index.js"
  },
  "files": [
    "src",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "sync-templates": "node scripts/sync-templates.js",
    "prepack": "npm run sync-templates",
    "pack:release": "npm pack",
    "start": "node src/index.js",
    "init": "node src/index.js init",
    "check": "node --check src/index.js && node --check src/services/init.js"
  }
}
